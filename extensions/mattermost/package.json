{
  "name": "@autocrab/mattermost",
  "version": "2026.3.2",
  "description": "AutoCrab Mattermost channel plugin",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./*.ts",
      "default": "./*.js"
    }
  },
  "dependencies": {
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "autocrab": "workspace:*"
  },
  "autocrab": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "mattermost",
      "label": "Mattermost",
      "selectionLabel": "Mattermost (plugin)",
      "docsPath": "/channels/mattermost",
      "docsLabel": "mattermost",
      "blurb": "self-hosted Slack-style chat; install the plugin to enable.",
      "order": 65
    },
    "install": {
      "npmSpec": "@autocrab/mattermost",
      "localPath": "extensions/mattermost",
      "defaultChoice": "npm"
    }
  }
}
